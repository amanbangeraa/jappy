# Neon Postgres connection string
# Get this from https://console.neon.tech → your project → Connection Details
# Format: postgresql://user:password@ep-xxx.us-east-2.aws.neon.tech/dbname?sslmode=require
DATABASE_URL=postgresql://user:password@ep-example.us-east-2.aws.neon.tech/dbname?sslmode=require

# Choose database source when running locally: neon | local
JAPPY_DB_SOURCE=neon

# Optional local Postgres connection string used by CSV import script
# Example: postgresql://postgres:postgres@localhost:5432/jappy_local
LOCAL_DATABASE_URL=postgresql://postgres:postgres@localhost:5432/jappy_local

# Admin registration secret key
# Required to register as an admin user. Set this to a strong random string.
ADMIN_SECRET=your-admin-secret-here