{
  "name": "jappy",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "node --dns-result-order=ipv4first node_modules/vite/bin/vite.js",
    "dev:localdb": "JAPPY_DB_SOURCE=local node --dns-result-order=ipv4first node_modules/vite/bin/vite.js",
    "dev:neondb": "JAPPY_DB_SOURCE=neon node --dns-result-order=ipv4first node_modules/vite/bin/vite.js",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "export:csv": "node scripts/export-db-to-csv.mjs",
    "import:csv": "node scripts/import-csv-to-local-db.mjs"
  },
  "dependencies": {
    "@neondatabase/serverless": "^1.1.0",
    "@types/pg": "^8.20.0",
    "bcryptjs": "^3.0.3",
    "dexie": "^4.4.3",
    "papaparse": "^5.5.3",
    "pg": "^8.22.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-router-dom": "^7.17.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@tailwindcss/vite": "^4.3.1",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^24.12.3",
    "@types/papaparse": "^5.5.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "tailwindcss": "^4.3.1",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.59.2",
    "vite": "^8.0.12"
  }
}
